<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Constelações - O Mapa Celeste</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0a0f2e 0%, #1a1f3a 50%, #0f172a 100%);
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* Efeito de estrelas cintilantes */
        .stars {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .star {
            position: absolute;
            background: white;
            border-radius: 50%;
            animation: twinkle 4s infinite ease-in-out;
        }

        @keyframes twinkle {

            0%,
            100% {
                opacity: 0.2;
                transform: scale(0.8);
            }

            50% {
                opacity: 1;
                transform: scale(1.2);
            }
        }

        /* Estrelas cadentes */
        .shooting-star {
            position: absolute;
            width: 4px;
            height: 4px;
            background: linear-gradient(45deg, transparent, #fff, transparent);
            border-radius: 50%;
            filter: drop-shadow(0 0 6px #fff);
            animation: shoot 6s linear infinite;
        }

        @keyframes shoot {
            0% {
                transform: translateX(0) translateY(0) rotate(45deg);
                opacity: 1;
            }

            70% {
                opacity: 1;
            }

            100% {
                transform: translateX(100vw) translateY(20vh) rotate(45deg);
                opacity: 0;
            }
        }

        .container {
            position: relative;
            z-index: 1;
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 4rem;
            padding: 2rem;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            animation: fadeInDown 1s ease-out;
        }

        .header h1 {
            font-size: 4rem;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, #f0e6d0, #c4b5a0, #a89b8c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 30px rgba(255, 215, 0, 0.3);
            letter-spacing: 4px;
        }

        .header p {
            font-size: 1.3rem;
            color: #b8c7e7;
            font-style: italic;
        }

        /* Cards de constelações */
        .constelacoes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
            margin-bottom: 4rem;
        }

        .card {
            background: rgba(20, 25, 45, 0.8);
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 30px;
            padding: 2rem;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            animation: fadeInUp 1s ease-out;
            animation-fill-mode: both;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

        .card:hover {
            transform: translateY(-15px) scale(1.02);
            border-color: rgba(255, 215, 0, 0.5);
            box-shadow: 0 30px 40px -15px rgba(0, 0, 0, 0.5),
                0 0 30px rgba(255, 215, 0, 0.3);
        }

        .card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at center, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.5s;
            transform: rotate(30deg);
        }

        .card:hover::before {
            opacity: 1;
        }

        .card-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
            filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.5));
            animation: float 3s ease-in-out infinite;
        }

        .card h3 {
            font-size: 2rem;
            margin-bottom: 1rem;
            color: #ffd700;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
        }

        .card p {
            color: #b0c0e0;
            line-height: 1.6;
            margin-bottom: 1rem;
        }

        .card-info {
            display: flex;
            justify-content: space-between;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            font-size: 0.9rem;
            color: #8a9ac0;
        }

        .card-info span {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        /* Seção Mitologia */
        .mitologia {
            margin-top: 4rem;
            padding: 3rem;
            background: rgba(10, 15, 30, 0.7);
            backdrop-filter: blur(10px);
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .mitologia h2 {
            font-size: 2.5rem;
            margin-bottom: 2rem;
            text-align: center;
            color: #ffd700;
            text-shadow: 0 0 15px rgba(255, 215, 0, 0.3);
        }

        .mitologia-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        .mitologia-item {
            text-align: center;
            padding: 1.5rem;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 30px;
            transition: transform 0.3s;
        }

        .mitologia-item:hover {
            transform: scale(1.05);
            background: rgba(255, 215, 0, 0.05);
        }

        .mitologia-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .mitologia-item h3 {
            color: #e0b0ff;
            margin-bottom: 0.5rem;
        }

        .mitologia-item p {
            color: #b0c0e0;
            line-height: 1.6;
        }

        /* Footer */
        .footer {
            margin-top: 4rem;
            text-align: center;
            padding: 2rem;
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            border-radius: 50px;
        }

        .footer p {
            color: #8a9ac0;
        }

        .footer a {
            color: #ffd700;
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer a:hover {
            color: #fff;
            text-decoration: underline;
        }

        /* Animações */
        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-10px);
            }
        }

        /* Atraso nas animações dos cards */
        .card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .card:nth-child(2) {
            animation-delay: 0.2s;
        }

        .card:nth-child(3) {
            animation-delay: 0.3s;
        }

        .card:nth-child(4) {
            animation-delay: 0.4s;
        }

        .card:nth-child(5) {
            animation-delay: 0.5s;
        }

        .card:nth-child(6) {
            animation-delay: 0.6s;
        }

        /* Responsividade */
        @media (max-width: 768px) {
            .header h1 {
                font-size: 2.5rem;
            }

            .header p {
                font-size: 1rem;
            }

            .container {
                padding: 1rem;
            }

            .mitologia {
                padding: 1.5rem;
            }
        }

        /* Efeito de brilho no texto */
        .glow-text {
            animation: glow 3s ease-in-out infinite;
        }

        @keyframes glow {

            0%,
            100% {
                text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
            }

            50% {
                text-shadow: 0 0 20px rgba(255, 215, 0, 0.6);
            }
        }
    </style>
</head>

<body>
    <!-- Estrelas de fundo -->
    <div class="stars" id="stars"></div>

    <!-- Estrelas cadentes -->
    <div class="shooting-star" style="top: 10%; left: -10%; animation-delay: 2s;"></div>
    <div class="shooting-star" style="top: 30%; left: -10%; animation-delay: 5s;"></div>
    <div class="shooting-star" style="top: 50%; left: -10%; animation-delay: 8s;"></div>
    <div class="shooting-star" style="top: 70%; left: -10%; animation-delay: 11s;"></div>

    <div class="container">
        <!-- Header -->
        <header class="header">
            <h1 class="glow-text">✨ CONSTELAÇÕES ✨</h1>
            <p>Descubra os segredos do céu noturno e as histórias escritas nas estrelas</p>
        </header>

        <!-- Cards de constelações -->
        <div class="constelacoes-grid">
            <!-- Órion -->
            <div class="card">
                <div class="card-icon">🌌</div>
                <h3>Órion</h3>
                <p>O Caçador - Uma das constelações mais reconhecíveis, famosa por suas "Três Marias" e pela nebulosa de
                    Órion.</p>
                <div class="card-info">
                    <span>⭐ Estrelas principais: 7</span>
                    <span>🌍 Hemisfério: Norte/Sul</span>
                </div>
            </div>

            <!-- Ursa Maior -->
            <div class="card">
                <div class="card-icon">🐻</div>
                <h3>Ursa Maior</h3>
                <p>A Grande Ursa - Contém o famoso "Grande Carro" e é uma das constelações mais antigas conhecidas.</p>
                <div class="card-info">
                    <span>⭐ Estrelas principais: 7</span>
                    <span>🌍 Hemisfério: Norte</span>
                </div>
            </div>

            <!-- Cruzeiro do Sul -->
            <div class="card">
                <div class="card-icon">✝️</div>
                <h3>Cruzeiro do Sul</h3>
                <p>A menor de todas as 88 constelações, mas uma das mais importantes para o hemisfério sul.</p>
                <div class="card-info">
                    <span>⭐ Estrelas principais: 4</span>
                    <span>🌍 Hemisfério: Sul</span>
                </div>
            </div>

            <!-- Andrômeda -->
            <div class="card">
                <div class="card-icon">👸</div>
                <h3>Andrômeda</h3>
                <p>Nomeada em homenagem à princesa da mitologia grega. Abriga a galáxia de Andrômeda, visível a olho nu.
                </p>
                <div class="card-info">
                    <span>⭐ Estrelas principais: 16</span>
                    <span>🌍 Hemisfério: Norte</span>
                </div>
            </div>

            <!-- Cão Maior -->
            <div class="card">
                <div class="card-icon">🐕</div>
                <h3>Cão Maior</h3>
                <p>Lar de Sirius, a estrela mais brilhante do céu noturno. Representa um dos cães de caça de Órion.</p>
                <div class="card-info">
                    <span>⭐ Estrelas principais: 8</span>
                    <span>🌍 Hemisfério: Sul</span>
                </div>
            </div>

            <!-- Cassiopeia -->
            <div class="card">
                <div class="card-icon">👑</div>
                <h3>Cassiopeia</h3>
                <p>Representa a rainha vaidosa da mitologia grega. Suas estrelas formam um "W" ou "M" no céu.</p>
                <div class="card-info">
                    <span>⭐ Estrelas principais: 5</span>
                    <span>🌍 Hemisfério: Norte</span>
                </div>
            </div>
        </div>

        <!-- Seção Mitologia -->
        <section class="mitologia">
            <h2>📜 Mitologia e Curiosidades</h2>
            <div class="mitologia-grid">
                <div class="mitologia-item">
                    <div class="mitologia-icon">🏛️</div>
                    <h3>Origem Grega</h3>
                    <p>Muitas constelações têm origem na mitologia grega, representando deuses, heróis e criaturas
                        míticas.</p>
                </div>
                <div class="mitologia-item">
                    <div class="mitologia-icon">🌍</div>
                    <h3>Navegação</h3>
                    <p>Por séculos, as constelações guiaram navegadores e exploradores pelos oceanos do mundo.</p>
                </div>
                <div class="mitologia-item">
                    <div class="mitologia-icon">📅</div>
                    <h3>Zodíaco</h3>
                    <p>As 12 constelações do zodíaco formam a base da astrologia e marcam o caminho do Sol no céu.</p>
                </div>
                <div class="mitologia-item">
                    <div class="mitologia-icon">🔭</div>
                    <h3>88 Oficiais</h3>
                    <p>A União Astronômica Internacional reconhece oficialmente 88 constelações que cobrem todo o céu.
                    </p>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="footer">
            <p>✨ "Olhe para as estrelas e sonhe" ✨</p>
            <p style="margin-top: 1rem; font-size: 0.9rem;">
                As constelações são janelas para o infinito •
                <a href="#">Explorar mais</a> •
                <a href="#">Mapa celeste</a>
            </p>
            <p style="margin-top: 1rem; font-size: 0.8rem; opacity: 0.7;">
                © 2024 Atlas Celeste - Todos os direitos reservados
            </p>
        </footer>
    </div>

    <script>
        // Gerar estrelas de fundo
        function createStars() {
            const starsContainer = document.getElementById('stars');
            const numberOfStars = 200;

            for (let i = 0; i < numberOfStars; i++) {
                const star = document.createElement('div');
                star.className = 'star';

                // Posição aleatória
                const x = Math.random() * 100;
                const y = Math.random() * 100;

                // Tamanho aleatório
                const size = Math.random() * 3;

                // Atraso na animação
                const delay = Math.random() * 5;

                star.style.left = x + '%';
                star.style.top = y + '%';
                star.style.width = size + 'px';
                star.style.height = size + 'px';
                star.style.animationDelay = delay + 's';

                starsContainer.appendChild(star);
            }
        }

        createStars();

        // Efeito de hover nos cards
        const cards = document.querySelectorAll('.card');
        cards.forEach(card => {
            card.addEventListener('click', () => {
                card.style.transform = 'scale(0.95)';
                setTimeout(() => {
                    card.style.transform = '';
                }, 200);
            });
        });

        // Atualizar ano no footer
        document.addEventListener('DOMContentLoaded', function () {
            const year = new Date().getFullYear();
            const footerText = document.querySelector('.footer p:last-child');
            if (footerText) {
                footerText.innerHTML = `© ${year} Atlas Celeste - Todos os direitos reservados`;
            }
        });
    </script>
</body>

</html>